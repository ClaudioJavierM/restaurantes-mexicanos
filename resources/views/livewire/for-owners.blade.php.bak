            </div>
        </div>
    </div>

    {{-- CTA Section --}}
    <div id="claim" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
        <h2 class="text-4xl font-bold text-gray-900 mb-6">
            Ready to Grow Your Restaurant?
        </h2>
        <p class="text-xl text-gray-600 mb-8">
            Join thousands of Mexican restaurants reaching more customers every day
        </p>

        <div class="bg-white rounded-2xl shadow-xl p-8 border-2 border-gray-200">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Search for Your Restaurant</h3>

            <div class="max-w-2xl mx-auto">
                <div class="relative">
                    <input
                        type="text"
                        placeholder="Enter your restaurant name or address..."
                        class="w-full px-6 py-4 text-lg border-2 border-gray-300 rounded-lg focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none"
                    >
                    <button class="absolute right-2 top-2 px-6 py-2 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition">
                        Search
                    </button>
                </div>

                <p class="text-sm text-gray-600 mt-4">
                    Don't see your restaurant? <a href="#" class="text-green-600 hover:text-green-700 font-semibold">Add it now</a>
                </p>
            </div>
        </div>
    </div>
</div>
